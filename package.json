{
  "name": "card-mod-studio",
  "version": "0.1.0",
  "description": "Visual GUI editor for card-mod CSS styles in Home Assistant",
  "author": "Trolli / Troll-IT",
  "license": "MIT",
  "main": "dist/card-mod-studio.js",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite build --watch",
    "lint": "eslint src --ext .ts",
